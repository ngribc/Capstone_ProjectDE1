    AVG(trt_hours) as avg_resolution_time,
    AVG(cac) as avg_cac,
    AVG(roi) as avg_roi,
    AVG(nps_score) as nps_index,
    COUNT(ticket_id) as total_tickets
FROM metrics
GROUP BY 1
    );
  
  
